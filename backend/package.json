{
  "name": "learnhub-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/index.ts",
    "build": "tsc && tsc-alias -p tsconfig.json",
    "start": "node --env-file=../.env dist/index.js",
    "seed:admin": "tsx --env-file=../.env scripts/seed-admin.ts",
    "seed:student": "tsx --env-file=../.env scripts/seed-student.ts",
    "fix:invitation-indexes": "tsx --env-file=../.env scripts/fix-invitation-indexes.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jose": "^6.2.3",
    "mongoose": "^9.7.3",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.29",
    "@types/nodemailer": "^8.0.1",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
