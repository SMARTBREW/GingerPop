# MongoDB
MONGODB_URI=mongodb://localhost:27017/quiz

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this

# App URL (used in invite email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# Cloudinary (media uploads — audio, video, images)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# Or use separate keys:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# SMTP (optional — invite links print to console if omitted)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Ginger Pop <your-email@gmail.com>

# Seed accounts (npm run seed:admin)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@quiz.com
SUPER_ADMIN_PASSWORD=superadmin123

ADMIN_NAME=Admin
ADMIN_EMAIL=admin@quiz.com
ADMIN_PASSWORD=admin123
